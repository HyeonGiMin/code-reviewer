# PostgreSQL - 사용자, 레포지토리 설정, 코멘트
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=code_reviewer
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password

# MongoDB - diff 스냅샷, 로그 캐시
MONGODB_URI=mongodb://localhost:27017/code_reviewer

# NextAuth
AUTH_SECRET=your_auth_secret_here
AUTH_URL=http://localhost:3000

# 암호화 키 (AES-256-GCM) - 32바이트 hex (openssl rand -hex 32 로 생성)
ENCRYPTION_KEY=your_32byte_hex_key_here
